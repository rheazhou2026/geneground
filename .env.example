# Server-side only. Never exposed to the browser. When unset or empty,
# every /api/claude/* route falls back to the deterministic/mock pipeline.
ANTHROPIC_API_KEY=

# Optional. Overrides the model name in src/lib/claude/config.ts.
# ANTHROPIC_MODEL=claude-sonnet-5

# Client-visible toggle (defaults to true/on when unset). Set to "false" to
# skip calling /api/claude/* routes entirely from the demo UI and always use
# the local deterministic/mock pipeline, even if ANTHROPIC_API_KEY is set.
NEXT_PUBLIC_GENEGROUND_USE_CLAUDE_API=true
